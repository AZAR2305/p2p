# Supabase project URL (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://uvftygdstvbxkjudtrep.supabase.co

# Supabase anon/public key (Project Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Optional (server-side admin actions only; never expose in client code)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Direct Postgres connection string (server only)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.uvftygdstvbxkjudtrep.supabase.co:5432/postgres

# Public app URL (used for auth callback redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional explicit redirect URL for local dev callback
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback

# Enable only when Vercel Web Analytics is configured for the project
NEXT_PUBLIC_ENABLE_VERCEL_ANALYTICS=false

# Optional reference metadata
SUPABASE_ORGANIZATION_SLUG=cdhmcjmuznesjhvnpvvy
